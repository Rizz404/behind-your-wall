# PostgreSQL
DATABASE_URL=postgresql://tracker_user:CHANGE_ME@localhost:5432/tracker_db?schema=public

# JWT (admin auth)
JWT_SECRET=CHANGE_ME_long_random_string
JWT_EXPIRES_IN=8h

# Redis cache (optional — leave empty/unset to run without a cache layer)
REDIS_URL=

# Cache TTLs (seconds)
SITE_KEY_CACHE_TTL=300

# App
PORT=3100

# IP enrichment
IP_ENRICHER_TIMEOUT_MS=3000

# Seed admin (used by prisma/seed.ts, Phase 2)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CHANGE_ME
